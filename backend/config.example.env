# Backend Environment Variables Template
# Copy this to config.env and fill in your actual values

NODE_ENV=production
PORT=8000

# MongoDB Connection (use MongoDB Atlas for production)
DATABASE_LOCAL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/HomelyHub

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Email Configuration (Mailtrap or other SMTP service)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=your_mailtrap_username
EMAIL_PASSWORD=your_mailtrap_password

# Stripe Payment Gateway
STRIPE_SECRECT_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Cloudinary Image Storage
CLOUD_NAME=your_cloudinary_name
CLOUD_KEY=your_cloudinary_api_key
CLOUD_KEY_SECRET=your_cloudinary_api_secret
